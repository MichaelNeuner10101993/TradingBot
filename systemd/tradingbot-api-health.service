[Unit]
Description=Trading Bot API/Liveness Healthcheck
After=network-online.target tradingbot-web.service

[Service]
Type=oneshot
EnvironmentFile=/root/bot/.env
WorkingDirectory=/root/bot
ExecStart=/root/bot/botvenv/bin/python /root/bot/watchdog/api_health.py
StandardOutput=journal
StandardError=journal
